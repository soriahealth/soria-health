# PostgreSQL connection string
# Local: postgresql://user@localhost:5432/soria_health
# Railway/Neon: provided automatically
DATABASE_URL=

# 32+ random characters. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Public API host for the mobile app to reach the backend.
# Local dev: tunnel domain (no protocol). Production: your Railway URL host.
EXPO_PUBLIC_DOMAIN=

# OpenAI key — required for Ask Me AI and Family Insights.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# SendGrid (transactional email) — for verification codes, alerts, password reset
# Get a key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Cloudflare R2 (document storage)
# Create a bucket + token at https://dash.cloudflare.com/?to=/:account/r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=soria-documents
R2_PUBLIC_URL=

# Google OAuth (optional, for "Continue with Google")
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
